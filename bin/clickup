#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["httpx>=0.27", "typer>=0.12"]
# ///
"""ClickUp CLI for Claude Code — direct ClickUp REST API v2 wrapper."""

import json
import os
import sys
from typing import NoReturn, Optional

import httpx
import typer

app = typer.Typer(no_args_is_help=True)
tasks_app = typer.Typer(no_args_is_help=True, help="Task CRUD and search")
comments_app = typer.Typer(no_args_is_help=True, help="Task comments")
app.add_typer(tasks_app, name="tasks")
app.add_typer(comments_app, name="comments")

_BASE = "https://api.clickup.com/api/v2"
_MAX_SEARCH_PAGES = 5  # cap client-side text search at 500 tasks


def _client() -> httpx.Client:
    key = os.environ.get("CLICKUP_API_KEY")
    if not key:
        _die("CLICKUP_API_KEY env var is not set")
    return httpx.Client(base_url=_BASE, headers={"Authorization": key}, timeout=30.0)


def _team(override: Optional[str] = None) -> str:
    tid = override or os.environ.get("CLICKUP_TEAM_ID")
    if not tid:
        _die("CLICKUP_TEAM_ID env var is not set (or pass --workspace-id)")
    return tid


def _out(data: object) -> None:
    print(json.dumps(data, indent=2))


def _die(msg: str) -> NoReturn:
    print(json.dumps({"error": msg}), file=sys.stderr)
    raise typer.Exit(1)


def _check(r: httpx.Response) -> dict:
    if r.status_code == 429:
        retry_after = r.headers.get("Retry-After", "unknown")
        _die(f"Rate limited by ClickUp. Retry after {retry_after}s.")
    if r.is_error:
        try:
            body = r.json()
            detail = body.get("err") or body.get("message") or r.text[:300]
        except Exception:
            detail = r.text[:300]
        _die(f"ClickUp API {r.status_code}: {detail}")
    if not r.content:
        return {}
    return r.json()


def _key(data: dict, key: str) -> object:
    val = data.get(key)
    if val is None:
        _die(f"Unexpected API response: missing '{key}' field")
    return val


# ── Workspaces ──────────────────────────────────────────────────────────────

@app.command("workspaces")
def workspaces() -> None:
    """List all workspaces accessible to the API key."""
    with _client() as c:
        _out(_key(_check(c.get("/team")), "teams"))


# ── Spaces ──────────────────────────────────────────────────────────────────

@app.command("spaces")
def spaces(
    workspace_id: Optional[str] = typer.Option(None, "--workspace-id", "-w", help="Default: CLICKUP_TEAM_ID"),
) -> None:
    """List spaces in a workspace."""
    with _client() as c:
        _out(_key(_check(c.get(f"/team/{_team(workspace_id)}/space", params={"archived": "false"})), "spaces"))


# ── Folders ──────────────────────────────────────────────────────────────────

@app.command("folders")
def folders(space_id: str = typer.Argument(..., help="Space ID")) -> None:
    """List folders in a space."""
    with _client() as c:
        _out(_key(_check(c.get(f"/space/{space_id}/folder", params={"archived": "false"})), "folders"))


# ── Lists ─────────────────────────────────────────────────────────────────────

@app.command("lists")
def lists(
    space_id: Optional[str] = typer.Option(None, "--space-id"),
    folder_id: Optional[str] = typer.Option(None, "--folder-id"),
) -> None:
    """List lists inside a space or folder."""
    if not space_id and not folder_id:
        _die("provide --space-id or --folder-id")
    with _client() as c:
        if folder_id:
            _out(_key(_check(c.get(f"/folder/{folder_id}/list", params={"archived": "false"})), "lists"))
        else:
            _out(_key(_check(c.get(f"/space/{space_id}/list", params={"archived": "false"})), "lists"))


# ── Tasks ─────────────────────────────────────────────────────────────────────

@tasks_app.command("search")
def tasks_search(
    query: Optional[str] = typer.Argument(None, help="Text to filter by task name (client-side substring match)"),
    workspace_id: Optional[str] = typer.Option(None, "--workspace-id", "-w", help="Default: CLICKUP_TEAM_ID"),
    list_id: Optional[str] = typer.Option(None, "--list-id", help="Scope to a specific list"),
    status: Optional[str] = typer.Option(None, "--status"),
    assignee: Optional[str] = typer.Option(None, "--assignee", help="User ID"),
    due_before: Optional[int] = typer.Option(None, "--due-before", help="Unix ms timestamp"),
    due_after: Optional[int] = typer.Option(None, "--due-after", help="Unix ms timestamp"),
    page: int = typer.Option(0, "--page", help="Page number (ignored when QUERY is set)"),
) -> None:
    """Search and filter tasks.

    With QUERY: fetches up to 500 tasks and filters by name substring (client-side).
    Without QUERY: returns one page of server-filtered tasks; check has_more for pagination.
    """
    params: dict = {}
    if status:
        params["statuses"] = status
    if assignee:
        params["assignees"] = assignee
    if due_before is not None:
        params["due_date_lt"] = due_before
    if due_after is not None:
        params["due_date_gt"] = due_after

    with _client() as c:
        if query:
            # ClickUp v2 has no server-side text search; paginate and filter client-side.
            all_tasks: list = []
            capped = True
            for p in range(_MAX_SEARCH_PAGES):
                params["page"] = p
                if list_id:
                    data = _check(c.get(f"/list/{list_id}/task", params=params))
                else:
                    data = _check(c.get(f"/team/{_team(workspace_id)}/task", params=params))
                page_tasks: list = data.get("tasks", [])
                all_tasks.extend(page_tasks)
                if len(page_tasks) < 100:
                    capped = False
                    break
            q = query.lower()
            matched = [t for t in all_tasks if q in t.get("name", "").lower()]
            _out({"tasks": matched, "has_more": capped})
        else:
            params["page"] = page
            if list_id:
                data = _check(c.get(f"/list/{list_id}/task", params=params))
            else:
                data = _check(c.get(f"/team/{_team(workspace_id)}/task", params=params))
            tasks: list = data.get("tasks", [])
            _out({"tasks": tasks, "has_more": len(tasks) == 100})


@tasks_app.command("get")
def tasks_get(task_id: str = typer.Argument(...)) -> None:
    """Get full details of a task by ID."""
    with _client() as c:
        _out(_check(c.get(f"/task/{task_id}")))


@tasks_app.command("create")
def tasks_create(
    list_id: str = typer.Option(..., "--list-id", "-l"),
    name: str = typer.Option(..., "--name", "-n"),
    description: Optional[str] = typer.Option(None, "--description", "-d"),
    status: Optional[str] = typer.Option(None, "--status", "-s"),
    priority: Optional[int] = typer.Option(None, "--priority", help="1=urgent 2=high 3=normal 4=low"),
    assignees: Optional[str] = typer.Option(None, "--assignees", help="Comma-separated numeric user IDs"),
    due_date: Optional[int] = typer.Option(None, "--due-date", help="Unix ms timestamp"),
) -> None:
    """Create a task in a list."""
    body: dict = {"name": name}
    if description is not None:
        body["description"] = description
    if status is not None:
        body["status"] = status
    if priority is not None:
        body["priority"] = priority
    if assignees:
        try:
            body["assignees"] = [int(a.strip()) for a in assignees.split(",")]
        except ValueError:
            _die("--assignees must be comma-separated numeric user IDs (e.g. 123,456)")
    if due_date is not None:
        body["due_date"] = due_date
    with _client() as c:
        _out(_check(c.post(f"/list/{list_id}/task", json=body)))


@tasks_app.command("update")
def tasks_update(
    task_id: str = typer.Argument(...),
    name: Optional[str] = typer.Option(None, "--name", "-n"),
    description: Optional[str] = typer.Option(None, "--description", "-d"),
    status: Optional[str] = typer.Option(None, "--status", "-s"),
    priority: Optional[int] = typer.Option(None, "--priority"),
    add_assignees: Optional[str] = typer.Option(None, "--add-assignees", help="Comma-separated numeric user IDs to add"),
    remove_assignees: Optional[str] = typer.Option(None, "--remove-assignees", help="Comma-separated numeric user IDs to remove"),
    due_date: Optional[int] = typer.Option(None, "--due-date", help="Unix ms timestamp"),
) -> None:
    """Update an existing task. Pass empty string to clear a text field."""
    body: dict = {}
    if name is not None:
        body["name"] = name
    if description is not None:
        body["description"] = description
    if status is not None:
        body["status"] = status
    if priority is not None:
        body["priority"] = priority
    if due_date is not None:
        body["due_date"] = due_date
    if add_assignees or remove_assignees:
        asgn: dict = {}
        try:
            if add_assignees:
                asgn["add"] = [int(a.strip()) for a in add_assignees.split(",")]
            if remove_assignees:
                asgn["rem"] = [int(a.strip()) for a in remove_assignees.split(",")]
        except ValueError:
            _die("--add-assignees / --remove-assignees must be comma-separated numeric user IDs")
        body["assignees"] = asgn
    with _client() as c:
        _out(_check(c.put(f"/task/{task_id}", json=body)))


@tasks_app.command("delete")
def tasks_delete(task_id: str = typer.Argument(...)) -> None:
    """Permanently delete a task."""
    with _client() as c:
        _check(c.delete(f"/task/{task_id}"))
    _out({"deleted": task_id})


# ── Comments ──────────────────────────────────────────────────────────────────

@comments_app.command("list")
def comments_list(task_id: str = typer.Argument(...)) -> None:
    """List all comments on a task."""
    with _client() as c:
        _out(_key(_check(c.get(f"/task/{task_id}/comment")), "comments"))


@comments_app.command("create")
def comments_create(
    task_id: str = typer.Argument(...),
    text: str = typer.Option(..., "--text", "-t"),
    notify_all: bool = typer.Option(False, "--notify-all/--no-notify-all", help="Notify all task watchers"),
) -> None:
    """Post a comment on a task."""
    with _client() as c:
        _out(_check(c.post(f"/task/{task_id}/comment", json={"comment_text": text, "notify_all": notify_all})))


if __name__ == "__main__":
    app()
