{
  "mcpServers": {
    "clickup": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/joelpt/clickup-mcp@82f4bd1eb5881bd5d3670f34d8118430913a7438",
        "clickup-mcp"
      ],
      "env": {
        "CLICKUP_API_KEY": "${CLICKUP_API_KEY}",
        "CLICKUP_TEAM_ID": "${CLICKUP_TEAM_ID}"
      }
    }
  }
}
